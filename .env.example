ConnectionStrings__DefaultConnection=Host=your-postgres-host;Port=5432;Database=POLIPERSJOURNAL;Username=postgres-user;Password=postgres-password
MSSQL_SOURCE_CONNECTION_STRING=Server=localhost;Database=PoliPersJournal;Trusted_Connection=True;TrustServerCertificate=True;Encrypt=False
MSSQL_SOURCE_SCHEMA=your_source_schema
APP_WWWROOT_PATH=/data/polipersjournal
JwtSettings__Secret=replace-with-a-long-random-secret
JwtSettings__Issuer=PoliPersJournal
JwtSettings__Audience=PoliPersJournal.Client
JwtSettings__TokenExpirationInMinutes=60
